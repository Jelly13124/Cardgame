[gd_scene load_steps=6 format=3 uid="uid://custom_unit_card"]

[ext_resource type="Script" path="res://battle_scene/play_card.gd" id="1_script"]

[sub_resource type="Shader" id="Shader_oval"]
code = "shader_type canvas_item;

void fragment() {
	vec2 uv = UV - vec2(0.5);
	// Standard circle in UV-space becomes an oval in non-square aspect ratios
	float dist = uv.x * uv.x * 4.0 + uv.y * uv.y * 4.0;
	if (dist > 1.0) {
		discard;
	}
}"

