; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="CardFramework"
run/main_scene="res://run_system/ui/main_menu.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")

[autoload]

Settings="*res://run_system/core/settings.gd"
RunManager="*res://run_system/core/run_manager.gd"
MetaProgress="*res://run_system/core/meta_progress.gd"
Tooltip="*res://run_system/core/tooltip.gd"
AudioManager="*res://run_system/core/audio_manager.gd"
SceneTransition="*res://run_system/core/scene_transition.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/mode=1
window/size/initial_position_type=4
window/stretch/mode="viewport"

[dotnet]

project/assembly_name="CardFramework"

[gui]

theme/custom_font="res://assets/fonts/NotoSansCJKsc-Regular.otf"
theme/default_font_size=20
